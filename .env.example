# App
APP_ENV=development
APP_NAME=TaskAlloc API
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-must-be-32-chars-min

# Database
DATABASE_URL=postgresql+asyncpg://taskalloc_user:taskalloc_pass@localhost:5432/taskalloc_db

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_PER_MINUTE=100

# Optional (future)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
